# ============================================
# CT Tracker - Environment Variables
# ============================================
# Copy this to .env.local for local development
# Add these as Environment Variables in Vercel
# ============================================

# Supabase (get from supabase.com > Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Meta Pixel & Conversions API
# Pixel ID: from Meta Events Manager
# Access Token: from Meta Business Suite > Events Manager > Settings > Conversions API
META_PIXEL_ID=your-pixel-id
META_ACCESS_TOKEN=your-conversions-api-token

# Stats API Key (generate a random string for dashboard auth)
STATS_API_KEY=generate-a-random-key-here

# IP Hashing Salt (any random string for privacy)
IP_SALT=your-random-salt-here
